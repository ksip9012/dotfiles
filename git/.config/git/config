[init]
	defaultBranch = main
[core]
	symlinks = true
	editor = nvim
	pager = delta
[alias]
	lg = log --oneline --graph --decorate --all
	st = status -s
[pull]
	rebase = true
[push]
	autoSetupRemote = true
[diff]
	tool = nvimdiff
	colorMoved = default
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	side-by-side = true
[merge]
	conflictstyle = diff3
[include]
	path = ~/.config/git/local
